---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const releases = await getCollection('releases');
const artists = await getCollection('artists');

const sortedReleases = releases
  .filter(r => r.data.status === 'live')
  .sort((a, b) => {
    const dateA = a.data.dates?.released ?? '';
    const dateB = b.data.dates?.released ?? '';
    return dateB.localeCompare(dateA);
  });

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'OurMusi.cc',
  url: Astro.site,
  description: 'Independent Creative Commons label for ambient, piano, and experimental music.',
};
---

<Layout title="OurMusi.cc — Independent Creative Commons Music">
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <Header />

  <main id="main">

  <!-- Hero -->
  <section class="px-6 py-20 max-w-2xl">
    <h1 class="text-4xl font-light tracking-tight text-foreground mb-4 leading-snug">
      Music made to be shared.
    </h1>
    <p class="text-lg text-muted leading-relaxed">
      OurMusi.cc releases ambient, piano, and experimental music under Creative Commons —
      free to use in podcasts, films, games, and beyond, with attribution.
    </p>
  </section>

  <!-- Artists -->
  <section class="px-6 pb-16">
    <h2 class="text-xs uppercase tracking-widest text-subtle mb-6">Artists</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 max-w-4xl">
      {artists.map(artist => (
        <a
          href={`/artists/${artist.data.id}`}
          class="group border border-border rounded-lg p-5 bg-surface hover:bg-surface-raised hover:border-accent-dim transition-colors"
        >
          <p class="font-medium text-foreground">{artist.data.display_name}</p>
          <p class="text-sm text-muted mt-1 line-clamp-2">{artist.data.bio.short}</p>
          {artist.data.genre_tags && (
            <div class="flex flex-wrap gap-1 mt-3">
              {artist.data.genre_tags.map(tag => (
                <span class="text-xs text-subtle bg-background px-2 py-0.5 rounded">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  </section>

  <!-- Recent Releases -->
  <section class="px-6 pb-20">
    <h2 class="text-xs uppercase tracking-widest text-subtle mb-6">Recent Releases</h2>
    <div class="grid gap-0 max-w-4xl">
      {sortedReleases.slice(0, 6).map(release => (
        <a
          href={`/releases/${release.data.artist_id}/${release.data.id}`}
          class="group flex items-baseline justify-between border-b border-border-muted py-3 hover:bg-surface px-3 -mx-3 rounded transition-colors"
        >
          <div class="flex items-baseline gap-4">
            <span class="font-medium text-foreground">{release.data.title}</span>
            <span class="text-sm text-subtle capitalize">{release.data.release_type}</span>
          </div>
          <span class="text-sm text-subtle tabular-nums shrink-0">
            {release.data.dates?.released?.slice(0, 4) ?? ''}
          </span>
        </a>
      ))}
    </div>
    {sortedReleases.length > 6 && (
      <a href="/releases" class="inline-block mt-6 text-sm text-accent hover:text-foreground transition-colors">
        View all {sortedReleases.length} releases →
      </a>
    )}
  </section>

  </main>

  <Footer />

</Layout>
