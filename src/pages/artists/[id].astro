---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map(artist => ({ params: { id: artist.data.id } }));
}

const { id } = Astro.params;
const artist = await getEntry('artists', id);
if (!artist) return Astro.redirect('/artists');

const allReleases = await getCollection('releases');
const releases = allReleases
  .filter(r => r.data.artist_id === id && r.data.status === 'live')
  .sort((a, b) => {
    const dateA = a.data.dates?.released ?? '';
    const dateB = b.data.dates?.released ?? '';
    return dateB.localeCompare(dateA);
  });

const { data: a } = artist;

// Official site first, then streaming, then social
const platformLinks = [
  a.contact?.website             && { label: 'Official site',  url: a.contact.website },
  a.platforms?.bandcamp_url      && { label: 'Bandcamp',       url: a.platforms.bandcamp_url },
  a.platforms?.spotify_artist_id && { label: 'Spotify',        url: `https://open.spotify.com/artist/${a.platforms.spotify_artist_id}` },
  a.platforms?.apple_music_artist_id && { label: 'Apple Music', url: `https://music.apple.com/artist/${a.platforms.apple_music_artist_id}` },
  a.platforms?.soundcloud_url    && { label: 'SoundCloud',     url: a.platforms.soundcloud_url },
  a.platforms?.subvert_fm_url    && { label: 'Subvert.fm',     url: a.platforms.subvert_fm_url },
  a.platforms?.fma_url           && { label: 'Free Music Archive', url: a.platforms.fma_url },
  a.platforms?.youtube_channel_id && { label: 'YouTube',       url: `https://www.youtube.com/channel/${a.platforms.youtube_channel_id}` },
  a.platforms?.instagram_handle  && { label: 'Instagram',      url: `https://instagram.com/${a.platforms.instagram_handle}` },
  a.platforms?.facebook_url      && { label: 'Facebook',       url: a.platforms.facebook_url },
].filter(Boolean) as { label: string; url: string }[];

const artistSchema = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: a.display_name,
  description: a.bio.short,
  genre: a.genre_tags,
  url: Astro.url.href,
  sameAs: platformLinks.map(p => p.url),
};
---

<Layout title={`${a.display_name} — OurMusi.cc`} description={a.bio.short}>
  <script type="application/ld+json" set:html={JSON.stringify(artistSchema)} />

  <Header />

  <main id="main" class="px-6 py-16 max-w-3xl">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-sm text-subtle mb-8">
      <ol class="flex items-center">
        <li><a href="/artists" class="hover:text-muted transition-colors">Artists</a></li>
        <li><span class="mx-2" aria-hidden="true">›</span></li>
        <li><span class="text-muted" aria-current="page">{a.display_name}</span></li>
      </ol>
    </nav>

    <!-- Name + tags -->
    <h1 class="text-3xl font-light tracking-tight text-foreground mb-3">{a.display_name}</h1>
    {a.genre_tags && (
      <div class="flex flex-wrap gap-1.5 mb-8">
        {a.genre_tags.map(tag => (
          <span class="text-xs text-subtle bg-surface px-2.5 py-1 rounded border border-border">{tag}</span>
        ))}
      </div>
    )}

    <!-- Bio -->
    <p class="text-base text-muted leading-relaxed mb-10">{a.bio.medium ?? a.bio.short}</p>

    <!-- Platform links -->
    {platformLinks.length > 0 && (
      <div class="flex flex-wrap gap-3 mb-16">
        {platformLinks.map(({ label, url }) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-muted border border-border px-4 py-1.5 rounded hover:border-accent-dim hover:text-foreground transition-colors"
          >
            {label}<span class="sr-only"> (opens in new tab)</span>
          </a>
        ))}
      </div>
    )}

    <!-- Releases -->
    <section>
      <h2 class="text-xs uppercase tracking-widest text-subtle mb-6">Discography</h2>
      <div class="grid gap-0">
        {releases.map(release => (
          <a
            href={`/releases/${release.data.artist_id}/${release.data.id}`}
            class="group flex items-baseline justify-between border-b border-border-muted py-3 hover:bg-surface px-3 -mx-3 rounded transition-colors"
          >
            <div class="flex items-baseline gap-4">
              <span class="font-medium text-foreground">{release.data.title}</span>
              <span class="text-sm text-subtle capitalize">{release.data.release_type}</span>
            </div>
            <span class="text-sm text-subtle tabular-nums shrink-0">
              {release.data.dates?.released?.slice(0, 4) ?? ''}
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- License note -->
    {a.default_license && (
      <p class="mt-12 text-sm text-subtle">
        All releases under <a href="/licensing" class="text-muted hover:text-foreground underline underline-offset-2 transition-colors">{a.default_license}</a>.
      </p>
    )}

  </main>

  <Footer />

</Layout>
