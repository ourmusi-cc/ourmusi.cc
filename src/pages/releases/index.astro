---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

const releases = await getCollection('releases');

// Sort by release date descending, live first
const sorted = releases
  .filter(r => r.data.status === 'live')
  .sort((a, b) => {
    const dateA = a.data.dates?.released ?? '';
    const dateB = b.data.dates?.released ?? '';
    return dateB.localeCompare(dateA);
  });

// Group by year
const byYear = sorted.reduce<Record<string, typeof sorted>>((acc, r) => {
  const year = r.data.dates?.released?.slice(0, 4) ?? 'Unknown';
  (acc[year] ??= []).push(r);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => b.localeCompare(a));
---

<Layout title="Releases — OurMusi.cc">

  <header class="border-b border-border px-6 py-5 flex items-center justify-between">
    <a href="/" class="text-base font-semibold tracking-tight text-foreground">OurMusi.cc</a>
    <nav class="flex gap-6 text-sm text-muted">
      <a href="/artists"   class="hover:text-foreground transition-colors">Artists</a>
      <a href="/releases"  class="text-foreground">Releases</a>
      <a href="/about"     class="hover:text-foreground transition-colors">About</a>
      <a href="/licensing" class="hover:text-foreground transition-colors">Licensing</a>
    </nav>
  </header>

  <main class="px-6 py-16 max-w-3xl">
    <h1 class="text-3xl font-light tracking-tight text-foreground mb-12">Releases</h1>

    {years.map(year => (
      <section class="mb-10">
        <h2 class="text-xs uppercase tracking-widest text-subtle mb-3">{year}</h2>
        <div class="grid gap-0">
          {byYear[year].map(release => (
            <a
              href={`/releases/${release.data.artist_id}/${release.data.id}`}
              class="group flex items-baseline justify-between border-b border-border-muted py-3 hover:bg-surface px-3 -mx-3 rounded transition-colors"
            >
              <div class="flex items-baseline gap-4">
                <span class="font-medium text-foreground">{release.data.title}</span>
                <span class="text-sm text-subtle capitalize">{release.data.release_type}</span>
              </div>
              <span class="text-sm text-subtle group-hover:text-muted transition-colors shrink-0">
                {release.data.artist_id.replace(/-/g, ' ')}
              </span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </main>

</Layout>
